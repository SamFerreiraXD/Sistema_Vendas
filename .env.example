# =========================================
# Configuração da aplicação
# =========================================
APP_NAME=ERP PDV
APP_ENV=development
DEBUG=True

# =========================================
# Banco de dados MySQL
# =========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=erp_user
DB_PASSWORD=erp_password
DB_NAME=erp_pdv
# Nota: DB_ROOT_PASSWORD é usado APENAS pelo Docker (docker-compose.yml)
# para configurar a senha do usuário root do MySQL. Não é necessário
# para a aplicação FastAPI.
DB_ROOT_PASSWORD=root_password

# String de conexão usada pelo SQLAlchemy
DATABASE_URL=mysql+pymysql://erp_user:erp_password@localhost:3306/erp_pdv

# =========================================
# Segurança / JWT
# =========================================
SECRET_KEY=troque_esta_chave_por_um_valor_aleatorio_e_seguro
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================
# CORS (origens permitidas, separadas por vírgula)
# =========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
